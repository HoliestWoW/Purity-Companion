<Window x:Class="PurityCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purity Companion" Width="480" SizeToContent="Height"
        Background="#0D0D11" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanMinimize" Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="DarkModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#050508"/>
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#252530"/>
                                <Setter Property="Foreground" Value="#555566"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="25">
        <StackPanel>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="P U R I T Y   C O M P A N I O N" Foreground="#F0F0F0" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Automated Cloud Sync &amp; Leaderboard Integration" Foreground="#7A7A8A" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Content="⚙ Options" Background="Transparent" Foreground="#8A8A9A" FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Click="OptionsButton_Click"/>
            </Grid>

            <Border Background="#16161C" BorderBrush="#252530" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" Foreground="#8A8A9A" FontSize="10" TextAlignment="Center" LineHeight="16">
                    By authenticating your Battle.net account and enabling cloud sync, you authorize this application to automatically detect successful Purity Challenge runs and submit your character data to the public leaderboard.
                </TextBlock>
            </Border>

            <TextBlock Text="1. AUTHENTICATION" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
            <Border Background="#16161C" BorderBrush="#252530" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="AuthStatusText" Text="Not Connected" Foreground="#FF4D4D" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Required for auto submissions and leaderboards." Foreground="#7A7A8A" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button x:Name="VerifyButton" Grid.Column="1" Content="Link Battle.net" Width="130" Height="34"
                            Background="#0078D4" Style="{StaticResource DarkModernButton}" Click="VerifyButton_Click"/>
                </Grid>
            </Border>

            <TextBlock Text="2. SYNC &amp; AUTO-UPLOAD ENGINE" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
            <Border Background="#16161C" BorderBrush="#252530" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Select your cloud pref to secure your data. (Not required for verifications)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,10"/>

                    <ComboBox x:Name="CloudProviderCombo" Margin="0,0,0,15" Height="28" Padding="5,0,0,0"
                              Background="#1E1E26" Foreground="Black" BorderBrush="#303040">
                        <ComboBoxItem Content="Google Drive" IsSelected="True"/>
                        <ComboBoxItem Content="OneDrive"/>
                        <ComboBoxItem Content="Custom Folder..."/>
                    </ComboBox>

                    <Button x:Name="AutomateSyncButton" Content="Enable Sync &amp; Auto-Upload" Height="38"
                            Background="#5C2D91" Style="{StaticResource DarkModernButton}" Click="AutomateSyncButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A24" CornerRadius="4" Padding="12,8" Margin="0,0,0,5">
                <TextBlock x:Name="StatusText" Text="Awaiting authentication..." Foreground="#8A8A9A" FontSize="11" 
                           TextWrapping="Wrap" TextAlignment="Center" LineHeight="16"/>
            </Border>

            <Button x:Name="LogToggleLink" Content="▼ View Session Activity History Log" Background="Transparent" Foreground="#4A90E2" 
                    FontSize="10" HorizontalAlignment="Center" BorderThickness="0" Cursor="Hand" Margin="0,2,0,0" Click="LogToggleLink_Click"/>

            <Border x:Name="LogHistoryPanel" Background="#07070A" BorderBrush="#1C1C24" BorderThickness="1" CornerRadius="4" 
                    Height="120" Margin="0,10,0,0" Padding="10" Visibility="Collapsed">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogHistoryText" 
         IsReadOnly="True" 
         TextWrapping="Wrap" 
         Background="Transparent" 
         Foreground="#6A6A7A" 
         BorderThickness="0" 
         FontFamily="Consolas" 
         FontSize="10.5" 
         IsReadOnlyCaretVisible="True">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" Command="Copy"/>
                                <MenuItem Header="Select All" Command="SelectAll"/>
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                </ScrollViewer>
            </Border>

            <Border x:Name="OptionsPanel" Background="#16161C" BorderBrush="#252530" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="SETTINGS" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <CheckBox x:Name="TrayCheckBox" Content="Minimize to system tray on close" Foreground="#CCCCCC" Margin="0,0,0,8" Click="Setting_Changed"/>
                    <CheckBox x:Name="NotifyCheckBox" Content="Show desktop notifications for uploads" Foreground="#CCCCCC" Margin="0,0,0,15" Click="Setting_Changed"/>
                    <Button Content="Log Out (Forget Battle.net Account)" Height="30" Background="#8B0000" Style="{StaticResource DarkModernButton}" Click="LogoutButton_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>